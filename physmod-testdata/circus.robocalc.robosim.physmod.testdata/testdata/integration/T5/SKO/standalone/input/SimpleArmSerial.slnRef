SolutionRef {
	expression Local { name M_inv type "matrix(real,2,2)" }
	method SKO::CholeskyAlgorithm
	order 5
input Local { name M_mass type "matrix(real,2,2)" }
input Local { name N type "real" }
constraint " (N) [ t == 0] ==2"
