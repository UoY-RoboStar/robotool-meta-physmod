SolutionRef {
	expression Local { name tau type "vector(real,2)" }
	method SKO::PlatformMapping
	order 1
input Local { name n type "int" }
constraint " (n) [ t == 0] ==3"
constraint " (tau) [ t == 0] ==zeroVec(2)"
constraint " (tau(0)) [ t == t] ==p_mapping.SimpleArmSerial.IntermediateLink.WristJoint.WristActuator.TorqueIn"
constraint " (tau(1)) [ t == t] ==p_mapping.SimpleArmSerial.BaseLink.ElbowJoint.ElbowActuator.TorqueIn"
}
SolutionRef {
	expression Local { name phi type "matrix(real,18,18)" }
	method SKO::Eval
	order 2
input Local { name B_1 type "matrix(real,4,4)" }
input Local { name B_2 type "matrix(real,4,4)" }
input Local { name B_3 type "matrix(real,4,4)" }
