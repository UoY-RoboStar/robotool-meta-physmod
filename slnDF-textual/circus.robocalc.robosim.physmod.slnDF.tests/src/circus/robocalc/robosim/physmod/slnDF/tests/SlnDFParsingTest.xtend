	@Test
	def void testHarmonicOscillatorPhysics() {
		val result = parseHelper.parse('''
			Solution {
			    datatypes {
			        OscillatorState {
			            position: float;     // displacement from equilibrium
			            velocity: float;     // velocity
			            acceleration: float  // acceleration
			        }
			    }
			    
			    state {
			        oscillator: OscillatorState = OscillatorState{position=1.0, velocity=0.0, acceleration=0.0};
			        spring_constant: float = 10.0;  // N/m
			        mass: float = 1.0;              // kg
			        damping: float = 0.1;           // damping coefficient
			        time: float = 0.0;              // current time
			        dt: float = 0.01;               // time step
			        energy_kinetic: float = 0.0;    // kinetic energy
			        energy_potential: float = 0.0;  // potential energy
			        energy_total: float = 0.0;       // total energy
			    }
			    
			    procedures {
			        procedure simulate_oscillator(val dt_val: float) {
			            // Calculate forces - note: val declarations not supported in procedure body
			            // spring_f = spring_force(spring_constant, oscillator.position);
			            // damping_f = damping_force(damping, oscillator.velocity);
			            
			            // Calculate acceleration directly without temp variables
			            oscillator.acceleration = calculate_acceleration(
			                spring_force(spring_constant, oscillator.position), 
			                damping_force(damping, oscillator.velocity), 
			                mass);
			            
			            // Integrate motion equations
			            oscillator.velocity = integrate_velocity(oscillator.velocity, oscillator.acceleration, dt_val);
			            oscillator.position = integrate_position(oscillator.position, oscillator.velocity, dt_val);
			            
			            // Update time
			            time = time + dt_val;
			        }
			        
			        procedure calculate_energy() {
			            energy_kinetic = kinetic_energy_calc(mass, oscillator.velocity);
			            energy_potential = potential_energy_calc(spring_constant, oscillator.position);
			            energy_total = energy_kinetic + energy_potential;
			        }
			    }
			    
			    functions {
			        // Hooke's law with damping: F = -kx - bv
			        function spring_force(k: float, position: float): float {
			            result == -k * position
			        }
			        
			        function damping_force(damping_coeff: float, velocity: float): float {
			            result == -damping_coeff * velocity
			        }
			        
			        // Newton's second law: a = F/m
			        function calculate_acceleration(spring_f: float, damping_f: float, mass: float): float {
			            result == (spring_f + damping_f) / mass
			        }
			        
			        // Energy calculations
			        function kinetic_energy_calc(mass: float, velocity: float): float {
			            result == 0.5 * mass * velocity * velocity
			        }
			        
			        function potential_energy_calc(k: float, position: float): float {
			            result == 0.5 * k * position * position
			        }
			        
			        // Integration methods
			        function integrate_velocity(v0: float, accel: float, dt: float): float {
			            result == v0 + accel * dt
			        }
			        
			        function integrate_position(x0: float, v0: float, dt: float): float {
			            result == x0 + v0 * dt
			        }
			    }
			    
			    computation {
			        // Simulate harmonic oscillator for 500 time steps
			        for (step: int in range(0, 500, 1)) {
			            simulate_oscillator(dt);
			            calculate_energy();
			        }
			    }
			}
		''')
		Assertions.assertNotNull(result)
		val errors = result.eResource.errors
		Assertions.assertTrue(errors.isEmpty, '''Harmonic Oscillator errors: «errors.join(", ")»''')
	}
