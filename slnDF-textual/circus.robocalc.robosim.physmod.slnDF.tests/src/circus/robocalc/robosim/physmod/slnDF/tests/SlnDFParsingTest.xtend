	@Test
	def void testForwardKinematicsPhysics() {
		val result = parseHelper.parse('''
			Solution {
			    datatypes {
			        JointState {
			            theta1: float;  // base rotation
			            theta2: float;  // shoulder angle
			            theta3: float   // elbow angle
			        };
			        
			        Position3D {
			            x: float;
			            y: float;
			            z: float
			        }
			    }
			    
			    state {
			        joints: JointState = JointState{theta1=0.0, theta2=0.0, theta3=0.0};
			        end_effector: Position3D = Position3D{x=0.0, y=0.0, z=0.0};
			        link1_length: float = 1.0;  // meters
			        link2_length: float = 0.8;  // meters
			        link3_length: float = 0.5;  // meters
			        time: float = 0.0;
			    }
			    
			    functions {
			        function cos(angle: float): float {
			            if (angle < 0.0) then result == cos(-angle) else
			            if (angle > 3.14159) then result == -cos(angle - 3.14159) else
			            result == 1.0 - angle*angle/2.0 + angle*angle*angle*angle/24.0
			        }
			        
			        function sin(angle: float): float {
			            if (angle < 0.0) then result == -sin(-angle) else
			            if (angle > 3.14159) then result == -sin(angle - 3.14159) else
			            result == angle - angle*angle*angle/6.0 + angle*angle*angle*angle*angle/120.0
			        }
			        
			        function forward_kinematics_x(theta1: float, theta2: float, theta3: float, l1: float, l2: float, l3: float): float {
			            result == cos(theta1) * (l1 + l2*cos(theta2) + l3*cos(theta2 + theta3))
			        }
			        
			        function forward_kinematics_y(theta1: float, theta2: float, theta3: float, l1: float, l2: float, l3: float): float {
			            result == sin(theta1) * (l1 + l2*cos(theta2) + l3*cos(theta2 + theta3))
			        }
			        
			        function forward_kinematics_z(theta2: float, theta3: float, l2: float, l3: float): float {
			            result == l2*sin(theta2) + l3*sin(theta2 + theta3)
			        }
			    }
			    
			    computation {
			        // Calculate forward kinematics
			        end_effector.x = forward_kinematics_x(joints.theta1, joints.theta2, joints.theta3, link1_length, link2_length, link3_length);
			        end_effector.y = forward_kinematics_y(joints.theta1, joints.theta2, joints.theta3, link1_length, link2_length, link3_length);
			        end_effector.z = forward_kinematics_z(joints.theta2, joints.theta3, link2_length, link3_length);
			        
			        time = time + 0.01;
			    }
			}
		''')
		Assertions.assertNotNull(result)
		val errors = result.eResource.errors
		Assertions.assertTrue(errors.isEmpty, '''Forward Kinematics errors: «errors.join(", ")»''')
	}
	
	@Test
	def void testPendulumLagrangianPhysics() {
		val result = parseHelper.parse('''
			Solution {
			    datatypes {
			        PendulumState {
			            theta: float;      // angle from vertical
			            theta_dot: float;  // angular velocity
			            theta_ddot: float  // angular acceleration
			        }
			    }
			    
			    state {
			        pendulum: PendulumState = PendulumState{theta=0.1, theta_dot=0.0, theta_ddot=0.0};
			        length: float = 1.0;           // pendulum length (m)
			        mass: float = 1.0;             // pendulum mass (kg) 
			        gravity: float = 9.81;         // gravitational acceleration (m/s^2)
			        damping: float = 0.1;          // damping coefficient
			        dt: float = 0.01;              // time step (s)
			        time: float = 0.0;             // current time
			        energy_kinetic: float = 0.0;   // kinetic energy
			        energy_potential: float = 0.0; // potential energy
			        energy_total: float = 0.0;     // total energy
			    }
			    
			    procedures {
			        procedure simulate_step(val dt_val: float) {
			            // Calculate acceleration using Lagrangian mechanics
			            pendulum.theta_ddot = pendulum_acceleration(gravity, length, pendulum.theta, pendulum.theta_dot, damping);
			            
			            // Integrate using Euler method
			            pendulum.theta_dot = pendulum.theta_dot + pendulum.theta_ddot * dt_val;
			            pendulum.theta = pendulum.theta + pendulum.theta_dot * dt_val;
			            
			            // Update time
			            time = time + dt_val;
			        }
			        
			        procedure calculate_energy() {
			            // Calculate energies using Lagrangian formulation
			            energy_kinetic = kinetic_energy(mass, length, pendulum.theta_dot);
			            energy_potential = potential_energy(mass, gravity, length, pendulum.theta);
			            energy_total = energy_kinetic + energy_potential;
			        }
			    }
			    
			    functions {
			        function cos(angle: float): float {
			            if (angle < 0.0) then result == cos(-angle) else 
			            if (angle > 3.14159) then result == -cos(angle - 3.14159) else
			            result == 1.0 - angle*angle/2.0 + angle*angle*angle*angle/24.0
			        }
			        
			        function sin(angle: float): float {
			            if (angle < 0.0) then result == -sin(-angle) else
			            if (angle > 3.14159) then result == -sin(angle - 3.14159) else
			            result == angle - angle*angle*angle/6.0 + angle*angle*angle*angle*angle/120.0
			        }
			        
			        function kinetic_energy(m: float, l: float, theta_dot: float): float {
			            result == 0.5 * m * l * l * theta_dot * theta_dot
			        }
			        
			        function potential_energy(m: float, g: float, l: float, theta: float): float {
			            result == m * g * l * (1.0 - cos(theta))
			        }
			        
			        function pendulum_acceleration(g: float, l: float, theta: float, theta_dot: float, b: float): float {
			            result == -(g / l) * sin(theta) - b * theta_dot
			        }
			    }
			    
			    computation {
			        // Initialize energy calculation
			        calculate_energy();
			        
			        // Simulation loop - 10 seconds of pendulum motion
			        for (step: int in range(0, 1000, 1)) {
			            simulate_step(dt);
			            calculate_energy();
			            
			            // Optional: Reset if pendulum goes too far (|theta| > pi)
			            if (pendulum.theta > 3.14159) {
			                pendulum.theta = pendulum.theta - 6.28318;
			            } else {
			                if (pendulum.theta < -3.14159) {
			                    pendulum.theta = pendulum.theta + 6.28318;
			                } else {
			                    skip;
			                }
			            }
			        }
			    }
			}
		''')
		Assertions.assertNotNull(result)
		val errors = result.eResource.errors
		Assertions.assertTrue(errors.isEmpty, '''Pendulum Lagrangian errors: «errors.join(", ")»''')
	}
	
